# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/sso

# Secret used by better-auth to sign sessions (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here

# Public base URL of this SSO app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://sso.localhost:3005

# JSON array of OAuth clients to seed (run: bun run db:seed)
# Each object: clientId, clientSecret, name, redirectUris (required) + optional fields
OAUTH_CLIENTS=[{"clientId":"mailer-dev","clientSecret":"change-me","name":"Mailer Dev","redirectUris":["http://mailer.localhost:3006/api/auth/sso/callback/internal"]}]

# Base URL of the email API service (no trailing slash)
EMAIL_API_URL=http://mailer.localhost:3006

# Bearer token for authenticating with the email API
EMAIL_API_TOKEN=your-email-api-token-here
