# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/sso

# Secret used by better-auth to sign sessions (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=your-secret-here

# Public base URL of this SSO app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Client secret for the seeded dev OAuth client (run: bun run db:seed)
DEV_CLIENT_SECRET=dev-secret
